- const wikiPosts = site.posts.filter(post => post.wiki && post.published !== false).sort('-updated').toArray()
- const totalCount = wikiPosts.length
- const totalChars = wikiPosts.reduce((sum, post) => sum + (post.content ? String(post.content).replace(/<[^>]+>/g, '').length : 0), 0)
- const latestPost = totalCount ? wikiPosts[0] : null

#article-container.container
  .wiki-hub
    .wiki-hero
      .wiki-hero__content
        p.wiki-kicker Knowledge Base
        h1 Wiki 笔记总览
        p.wiki-hero__desc
          | 这里聚合了我自己的技术笔记，按最近更新时间排序。
      .wiki-hero__stats
        .wiki-stat
          span.wiki-stat__label 文档总数
          strong.wiki-stat__value= totalCount
        .wiki-stat
          span.wiki-stat__label 内容字数
          strong.wiki-stat__value #{(totalChars / 1000).toFixed(1)}k
        .wiki-stat
          span.wiki-stat__label 最近更新
          strong.wiki-stat__value= latestPost ? date(latestPost.updated || latestPost.date, 'YYYY-MM-DD') : '暂无'

    if totalCount
      .wiki-toolbar
        label.wiki-toolbar__label(for='wiki-search-input') 快速检索
        input#wiki-search-input(type='search' placeholder='输入关键词，例如 Java / Redis / 算法')

      #wiki-grid.wiki-grid
        each post in wikiPosts
          - const link = post.link || post.path
          - const title = post.title || _p('no_title')
          - const source = String(post.content || '')
          - const summary = source.replace(/<figure class="highlight[\s\S]*?<\/figure>/g, ' ').replace(/<pre[\s\S]*?<\/pre>/g, ' ').replace(/<code[\s\S]*?<\/code>/g, ' ').replace(/<[^>]+>/g, ' ').replace(/&#x2F;|&#47;/gi, '/').replace(/&#39;/g, "'").replace(/&quot;/g, '"').replace(/&amp;/g, '&').replace(/\s+/g, ' ').trim().slice(0, 120)
          - const categoryName = post.categories && post.categories.length ? post.categories.data[0].name : 'Wiki'
          - const tagNames = post.tags && post.tags.length ? post.tags.data.map(tag => tag.name).join(' · ') : '笔记'
          article.wiki-card(data-search=(title + ' ' + summary + ' ' + tagNames).toLowerCase())
            .wiki-card__header
              span.wiki-card__pill= categoryName
              time(datetime=date_xml(post.updated || post.date))= date(post.updated || post.date, 'YYYY-MM-DD')
            h2.wiki-card__title
              a(href=url_for(link) title=title)= title
            p.wiki-card__summary= summary || '点击查看完整内容'
            .wiki-card__footer
              i.fas.fa-book-open
              span= tagNames

      #wiki-empty.wiki-empty(style='display:none')
        i.far.fa-folder-open
        p 没有匹配的笔记，试试其他关键词。
    else
      .wiki-empty
        i.far.fa-folder-open
        p 还没有可展示的 Wiki 笔记。

style.
  .page.type-wiki #page {
    background: transparent;
    box-shadow: none;
    border: 0;
    padding: 0;
  }

  .page.type-wiki #page .page-title {
    display: none;
  }

  .wiki-hub {
    --wiki-bg: linear-gradient(145deg, rgba(245, 249, 255, 0.92), rgba(238, 251, 247, 0.9));
    --wiki-border: rgba(84, 105, 212, 0.16);
    --wiki-text: #132643;
    --wiki-muted: #54657e;
    --wiki-accent: #1d4ed8;
    display: grid;
    gap: 20px;
  }

  .wiki-hero {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--wiki-border);
    border-radius: 24px;
    padding: clamp(1.2rem, 2.8vw, 1.8rem);
    background: var(--wiki-bg);
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 300px);
    align-items: end;
  }

  .wiki-hero::before {
    content: '';
    position: absolute;
    inset: -40% -10% auto auto;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle at center, rgba(37, 99, 235, 0.22), rgba(59, 130, 246, 0));
    pointer-events: none;
  }

  .wiki-kicker {
    margin: 0;
    color: #1e3a8a;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .wiki-hero h1 {
    margin: 0.35rem 0 0;
    font-size: clamp(1.8rem, 4vw, 2.3rem);
    line-height: 1.2;
    color: var(--wiki-text);
    font-family: 'LXGW WenKai', 'Noto Serif SC', 'Songti SC', serif;
  }

  .wiki-hero__desc {
    margin: 0.85rem 0 0;
    color: var(--wiki-muted);
    line-height: 1.85;
  }

  .wiki-hero__desc code {
    font-size: 0.9em;
    border-radius: 8px;
    padding: 0.1em 0.4em;
    background: rgba(15, 23, 42, 0.07);
    color: #1e3a8a;
  }

  .wiki-hero__stats {
    display: grid;
    gap: 10px;
  }

  .wiki-stat {
    border-radius: 14px;
    border: 1px solid rgba(29, 78, 216, 0.12);
    padding: 0.75rem 0.85rem;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(2px);
    display: grid;
    gap: 2px;
  }

  .wiki-stat__label {
    color: #516384;
    font-size: 0.84rem;
  }

  .wiki-stat__value {
    color: #0f1f3d;
    font-size: 1.15rem;
    font-weight: 700;
  }

  .wiki-toolbar {
    display: flex;
    gap: 0.7rem;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  .wiki-toolbar__label {
    color: #304563;
    font-weight: 600;
  }

  .wiki-toolbar input {
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.9);
    min-width: 300px;
    width: min(100%, 560px);
    padding: 0.68rem 0.8rem;
    color: #122033;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .wiki-toolbar input:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.18);
  }

  .wiki-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .wiki-card {
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 18px;
    padding: 1rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(248, 250, 252, 0.92));
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .wiki-card:hover {
    transform: translateY(-3px);
    border-color: rgba(37, 99, 235, 0.36);
    box-shadow: 0 12px 28px rgba(37, 99, 235, 0.14);
  }

  .wiki-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.7rem;
    color: #5b6f90;
    font-size: 0.86rem;
  }

  .wiki-card__pill {
    border-radius: 999px;
    background: rgba(29, 78, 216, 0.1);
    color: #1e3a8a;
    padding: 0.2rem 0.6rem;
    font-weight: 600;
  }

  .wiki-card__title {
    margin: 0;
    line-height: 1.35;
    font-size: 1.14rem;
    font-family: 'LXGW WenKai', 'Noto Serif SC', 'Songti SC', serif;
  }

  .wiki-card__title a {
    color: var(--wiki-text);
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0 100%;
    background-size: 0 1px;
    background-repeat: no-repeat;
    transition: background-size 0.2s ease;
  }

  .wiki-card__title a:hover {
    background-size: 100% 1px;
  }

  .wiki-card__summary {
    margin: 0.7rem 0 0;
    color: #4e6079;
    line-height: 1.7;
    min-height: 3.4em;
    font-size: 0.95rem;
  }

  .wiki-card__footer {
    margin-top: 0.8rem;
    color: #587295;
    font-size: 0.88rem;
    display: flex;
    align-items: center;
    gap: 0.42rem;
  }

  .wiki-empty {
    border: 1px dashed rgba(100, 116, 139, 0.4);
    border-radius: 14px;
    color: #64748b;
    text-align: center;
    padding: 1.8rem 1rem;
  }

  .wiki-empty i {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    display: block;
  }

  [data-theme='dark'] .wiki-hub {
    --wiki-bg: linear-gradient(145deg, rgba(15, 23, 42, 0.96), rgba(17, 34, 56, 0.94));
    --wiki-border: rgba(96, 165, 250, 0.22);
    --wiki-text: #e2e8f0;
    --wiki-muted: #cbd5e1;
  }

  [data-theme='dark'] .wiki-kicker,
  [data-theme='dark'] .wiki-hero__desc code,
  [data-theme='dark'] .wiki-card__pill {
    color: #bfdbfe;
  }

  [data-theme='dark'] .wiki-stat,
  [data-theme='dark'] .wiki-toolbar input,
  [data-theme='dark'] .wiki-card {
    background: rgba(30, 41, 59, 0.84);
    border-color: rgba(100, 116, 139, 0.42);
  }

  [data-theme='dark'] .wiki-stat__label,
  [data-theme='dark'] .wiki-card__header,
  [data-theme='dark'] .wiki-card__summary,
  [data-theme='dark'] .wiki-card__footer,
  [data-theme='dark'] .wiki-toolbar__label {
    color: #cbd5e1;
  }

  [data-theme='dark'] .wiki-stat__value,
  [data-theme='dark'] .wiki-card__title a {
    color: #f8fafc;
  }

  @media (max-width: 980px) {
    .wiki-hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 820px) {
    .wiki-toolbar {
      align-items: stretch;
    }

    .wiki-toolbar input {
      min-width: 0;
      width: 100%;
    }

    .wiki-grid {
      grid-template-columns: 1fr;
    }
  }

script.
  (() => {
    const input = document.getElementById('wiki-search-input');
    const cards = Array.from(document.querySelectorAll('.wiki-card'));
    const empty = document.getElementById('wiki-empty');
    if (!input || cards.length === 0) return;

    const applyFilter = () => {
      const key = input.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach(card => {
        const match = !key || card.dataset.search.includes(key);
        card.style.display = match ? '' : 'none';
        if (match) visible += 1;
      });
      if (empty) empty.style.display = visible === 0 ? '' : 'none';
    };

    input.addEventListener('input', applyFilter);
  })();
